# MoltMarket frontend configuration
# Copy to `frontend/.env.local` for local development or configure these vars in Vercel.

# Server-side URL the Next.js `/api/chat` route uses to call the Express backend.
MOLTMARKET_API_URL=http://127.0.0.1:3000

# Browser-side URL for skills, treasury, registry, and demo controls.
NEXT_PUBLIC_API_URL=http://127.0.0.1:3000

# Optional explicit WebSocket origin for split deployments.
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:3000

# Default provider path. Set AI_PROVIDER / CHAT_PROVIDER to `anthropic` or `google`
# only when the corresponding credentials are present.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional alternate providers.
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-5-20250929
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_CHAT_MODEL=gemini-2.5-flash
