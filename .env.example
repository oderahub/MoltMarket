# MoltMarket backend configuration
# Copy to `.env` and fill in real values for local or hosted environments.

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================
# Options: "testnet" or "mainnet"
STACKS_NETWORK=testnet

# Stacks API base URL
# Testnet: https://api.testnet.hiro.so
# Mainnet: https://api.hiro.so
STACKS_API_URL=https://api.testnet.hiro.so

# =============================================================================
# PLATFORM WALLET
# =============================================================================
# Generate with: npm run setup:wallets
# Never commit real private keys.
PLATFORM_PRIVATE_KEY=
PLATFORM_ADDRESS=

# =============================================================================
# PROVIDER WALLETS (optional for multi-hop demo)
# =============================================================================
PROVIDER_A_PRIVATE_KEY=
PROVIDER_A_ADDRESS=

PROVIDER_B_PRIVATE_KEY=
PROVIDER_B_ADDRESS=

PROVIDER_C_PRIVATE_KEY=
PROVIDER_C_ADDRESS=

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=3000
HOST=0.0.0.0

# =============================================================================
# PAYMENT CONFIGURATION
# =============================================================================
PLATFORM_FEE_PERCENT=40

# =============================================================================
# OPTIONAL FACILITATOR
# =============================================================================
# FACILITATOR_URL=https://x402-facilitator.stacksx402.com
